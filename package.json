{
	"name": "dynamic-array",
	"version": "0.1.0",
	"description": "A high-performance, dynamically resizing wrapper around JavaScript TypedArrays",
	"main": "dist/index.js",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"type": "module",
	"scripts": {
		"test": "bun test",
		"bench": "bun benchmarks/index.ts",
		"build": "bunup index.ts utils.ts --out-dir dist",
		"check": "biome check",
		"lint": "biome lint",
		"format": "biome format"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./utils": {
			"types": "./dist/utils.d.ts",
			"import": "./dist/utils.js",
			"default": "./dist/utils.js"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"keywords": [
		"typedarray",
		"dynamic-array",
		"performance",
		"memory-efficient",
		"webassembly",
		"webgpu",
		"arraybuffer",
		"buffer",
		"data-structures",
		"typescript"
	],
	"license": "MIT",
	"author": "",
	"repository": {
		"type": "git",
		"url": ""
	},
	"homepage": "",
	"devDependencies": {
		"@biomejs/biome": "2.3.11",
		"@types/bun": "latest",
		"@typescript/native-preview": "^7.0.0-dev.20260319.1",
		"@webgpu/types": "latest",
		"bun-webgpu": "latest",
		"bunup": "latest",
		"mitata": "latest",
		"typed-numarray": "latest"
	},
	"peerDependencies": {
		"typescript": "^5.9.3"
	}
}
